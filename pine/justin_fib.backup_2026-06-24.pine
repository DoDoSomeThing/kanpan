//@version=5
indicator("Justin Fib + 關鍵價位", overlay=true, max_lines_count=200, max_labels_count=200, max_boxes_count=100)

// ===== 模式 =====
mode     = input.string("Pivot 真轉折", "波段抓法", options=["Pivot 真轉折", "Lookback 區間極值"], group="模式")
pvLeft   = input.int(10, "Pivot 左腳", minval=1, group="模式", tooltip="只 Pivot 模式用")
pvRight  = input.int(10, "Pivot 右腳", minval=1, group="模式", tooltip="只 Pivot 模式用")
lookback = input.int(60, "Lookback 回看天數", minval=5, group="模式", tooltip="只 Lookback 模式用")

showMA5  = input.bool(true, "MA5",  group="均線")
showMA20 = input.bool(true, "MA20", group="均線")
showZones= input.bool(true, "Fib 色塊", group="顯示")
showFib  = input.bool(true, "Fib 線",   group="顯示")
rightExt = input.int(20, "向右延伸根數", group="顯示")
h1 = input.price(0.0, "水平線1", group="關鍵價位")
h2 = input.price(0.0, "水平線2", group="關鍵價位")
h3 = input.price(0.0, "水平線3", group="關鍵價位")
h4 = input.price(0.0, "水平線4", group="關鍵價位")

// 歷史支撐壓力（自動）：把歷史峰谷都當 S/R（你爸的做法）
grpSR   = "歷史支撐壓力（自動）"
showSR  = input.bool(true,  "畫歷史 S/R",   group=grpSR, tooltip="收集回看內的 pivot 高低點，相近合併成支撐壓力線")
srLook  = input.int(250,    "回看根數",      minval=20,  group=grpSR)
srMerge = input.float(1.5,  "合併帶寬%",     minval=0.1, group=grpSR, tooltip="兩條相距 < 此% 視為同一區只畫一條")
srMax   = input.int(8,      "壓力最多畫幾條(現價上)", minval=1, group=grpSR)
srSupN  = input.int(1,      "支撐最多畫幾條(現價下)", minval=1, group=grpSR, tooltip="前低支撐通常只看最近一條(最上面)")

// 真空區 LVN（多空分界）：成交量稀薄、價格快速穿越的帶
grpVac  = "真空區 LVN（多空分界）"
showVac = input.bool(true,  "標真空區",      group=grpVac, tooltip="成交量分布的低量節點=套牢盤稀薄，撐不住就快速穿越")
vacLen  = input.int(250,    "VP 窗(根)",     minval=20,  group=grpVac)
vacBins = input.int(50,     "VP 分格",       minval=10,  group=grpVac)
vacThr  = input.float(0.30, "低量門檻(×均量)", minval=0.05, maxval=1.0, group=grpVac)
vacNear = input.float(15.0, "只標現價±%內",  minval=1,   group=grpVac)

isPivot = mode == "Pivot 真轉折"

// ===== 抓波段高低 =====
// Pivot 模式
ph = ta.pivothigh(high, pvLeft, pvRight)
pl = ta.pivotlow(low,  pvLeft, pvRight)
var float pvHiP = na, var int pvHiX = na
var float pvLoP = na, var int pvLoX = na
if not na(ph)
    pvHiP := ph
    pvHiX := bar_index - pvRight
if not na(pl)
    pvLoP := pl
    pvLoX := bar_index - pvRight

// 歷史 S/R：累積所有 pivot 高低點（價 + bar），最後一根再篩回看內、合併、畫
var float[] srP = array.new_float()
var int[]   srB = array.new_int()
if not na(ph)
    array.push(srP, ph)
    array.push(srB, bar_index - pvRight)
if not na(pl)
    array.push(srP, pl)
    array.push(srB, bar_index - pvRight)

// 真空區用：對回看窗做成交量分布分桶，回 [hh, ll, 各桶量陣列]
f_binvol(simple int len, simple int bins) =>
    hh = ta.highest(high, len)
    ll = ta.lowest(low,  len)
    vol = array.new_float(bins, 0.0)
    if hh > ll
        step = (hh - ll) / bins
        for i = 0 to len - 1
            bl = math.max(0, math.min(bins - 1, int((low[i]  - ll) / step)))
            bh = math.max(0, math.min(bins - 1, int((high[i] - ll) / step)))
            per = nz(volume[i]) / (bh - bl + 1)
            for j = bl to bh
                array.set(vol, j, array.get(vol, j) + per)
    [hh, ll, vol]

// Lookback 模式
lbHi = ta.highest(high, lookback)
lbLo = ta.lowest(low,  lookback)

// 統一輸出
hiP = isPivot ? pvHiP : lbHi
loP = isPivot ? pvLoP : lbLo
hiX = isPivot ? pvHiX : bar_index - lookback
loX = isPivot ? pvLoX : bar_index - lookback

// ===== Fib =====
levels = array.from(0.0, 0.236, 0.382, 0.5, 0.618, 0.786, 1.0, 1.618)
cols   = array.from(color.gray, color.red, color.orange, color.green, color.teal, color.aqua, color.gray, color.purple)
var line[]  fLines = array.new_line()
var label[] fLabs  = array.new_label()
var box[]   fBoxes = array.new_box()

if barstate.islast and not na(hiP) and not na(loP)
    if array.size(fLines) > 0
        for i = 0 to array.size(fLines) - 1
            line.delete(array.get(fLines, i))
    if array.size(fLabs) > 0
        for i = 0 to array.size(fLabs) - 1
            label.delete(array.get(fLabs, i))
    if array.size(fBoxes) > 0
        for i = 0 to array.size(fBoxes) - 1
            box.delete(array.get(fBoxes, i))
    array.clear(fLines)
    array.clear(fLabs)
    array.clear(fBoxes)

    rng = hiP - loP
    xL  = math.min(hiX, loX)
    xR  = bar_index + rightExt

    px = close   // 現價,判壓力/支撐

    if showFib
        for i = 0 to array.size(levels) - 1
            r = array.get(levels, i)
            p = hiP - rng * r
            c = array.get(cols, i)
            sr = p > px ? "壓力" : "支撐"
            array.push(fLines, line.new(xL, p, xR, p, color=c, width=1))
            array.push(fLabs,  label.new(xR, p, str.format("{0} Fib {1} ({2})", sr, r, str.tostring(p, format.mintick)), style=label.style_label_left, color=color.new(c, 80), textcolor=c, size=size.small))

    if showZones
        for i = 0 to array.size(levels) - 2
            p1 = hiP - rng * array.get(levels, i)
            p2 = hiP - rng * array.get(levels, i + 1)
            array.push(fBoxes, box.new(xL, math.max(p1, p2), xR, math.min(p1, p2), border_color=color.new(color.gray, 100), bgcolor=color.new(array.get(cols, i + 1), 90)))

    // 關鍵水平線 (inline);壓力紅/支撐綠
    if h1 > 0
        c1 = h1 > px ? color.red : color.green
        array.push(fLines, line.new(xL, h1, xR, h1, color=c1, width=2))
        array.push(fLabs,  label.new(xR, h1, str.format("{0} {1}", h1 > px ? "壓力" : "支撐", str.tostring(h1)), style=label.style_label_left, color=color.new(c1, 50), textcolor=color.white, size=size.small))
    if h2 > 0
        c2 = h2 > px ? color.red : color.green
        array.push(fLines, line.new(xL, h2, xR, h2, color=c2, width=2))
        array.push(fLabs,  label.new(xR, h2, str.format("{0} {1}", h2 > px ? "壓力" : "支撐", str.tostring(h2)), style=label.style_label_left, color=color.new(c2, 50), textcolor=color.white, size=size.small))
    if h3 > 0
        c3 = h3 > px ? color.red : color.green
        array.push(fLines, line.new(xL, h3, xR, h3, color=c3, width=2))
        array.push(fLabs,  label.new(xR, h3, str.format("{0} {1}", h3 > px ? "壓力" : "支撐", str.tostring(h3)), style=label.style_label_left, color=color.new(c3, 50), textcolor=color.white, size=size.small))
    if h4 > 0
        c4 = h4 > px ? color.red : color.green
        array.push(fLines, line.new(xL, h4, xR, h4, color=c4, width=2))
        array.push(fLabs,  label.new(xR, h4, str.format("{0} {1}", h4 > px ? "壓力" : "支撐", str.tostring(h4)), style=label.style_label_left, color=color.new(c4, 50), textcolor=color.white, size=size.small))

    // 標的名稱 + 現價 (左上標題)
    array.push(fLabs, label.new(xL, hiP, str.format("{0}  現價 {1}", syminfo.ticker, str.tostring(px)), style=label.style_label_down, color=color.new(color.black, 30), textcolor=color.white, size=size.normal))

// ===== A 歷史支撐壓力 + B 真空區（最後一根畫，重畫前清乾淨，不重繪堆積）=====
var line[]  srLines  = array.new_line()
var label[] srLabs   = array.new_label()
var box[]   vacBoxes = array.new_box()

if barstate.islast
    if array.size(srLines) > 0
        for i = 0 to array.size(srLines) - 1
            line.delete(array.get(srLines, i))
    if array.size(srLabs) > 0
        for i = 0 to array.size(srLabs) - 1
            label.delete(array.get(srLabs, i))
    if array.size(vacBoxes) > 0
        for i = 0 to array.size(vacBoxes) - 1
            box.delete(array.get(vacBoxes, i))
    array.clear(srLines)
    array.clear(srLabs)
    array.clear(vacBoxes)

    pxNow = close
    xRn   = bar_index + rightExt
    xLn   = math.max(0, bar_index - srLook)

    // ---- A 歷史 S/R：篩回看內 pivot → 排序 → 合併相近叢集 → 畫 ----
    if showSR and array.size(srP) > 0
        cand = array.new_float()
        for i = 0 to array.size(srP) - 1
            if array.get(srB, i) >= bar_index - srLook
                array.push(cand, array.get(srP, i))
        if array.size(cand) > 0
            array.sort(cand, order.ascending)
            reps = array.new_float()
            cs    = array.get(cand, 0)      // 叢集價總和
            cn    = 1                        // 叢集成員數
            cbase = array.get(cand, 0)      // 叢集下緣
            if array.size(cand) > 1
                for i = 1 to array.size(cand) - 1
                    v = array.get(cand, i)
                    if (v - cbase) / cbase * 100 < srMerge
                        cs := cs + v
                        cn := cn + 1
                    else
                        array.push(reps, cs / cn)
                        cs    := v
                        cn    := 1
                        cbase := v
            array.push(reps, cs / cn)
            // 支撐(現價下)留最近 srSupN 條(最上面)；壓力(現價上)留最近 srMax 條
            below = array.new_float()
            above = array.new_float()
            for i = 0 to array.size(reps) - 1
                rp = array.get(reps, i)
                if rp < pxNow
                    array.push(below, rp)
                else
                    array.push(above, rp)
            picked = array.new_float()
            if array.size(below) > 0
                array.sort(below, order.descending)      // 最高(最近現價)在前
                cntB = int(math.min(srSupN, array.size(below)))
                for i = 0 to cntB - 1
                    array.push(picked, array.get(below, i))
            if array.size(above) > 0
                array.sort(above, order.ascending)       // 最低(最近現價)在前
                cntA = int(math.min(srMax, array.size(above)))
                for i = 0 to cntA - 1
                    array.push(picked, array.get(above, i))
            for i = 0 to array.size(picked) - 1
                p = array.get(picked, i)
                c = p > pxNow ? color.red : color.green
                dist = pxNow > 0 ? (p - pxNow) / pxNow * 100 : 0
                array.push(srLines, line.new(xLn, p, xRn, p, color=color.new(c, 20), width=1, style=line.style_dashed))
                array.push(srLabs, label.new(xRn, p, str.format("{0} {1} ({2}{3}%)", p > pxNow ? "前高壓力" : "前低支撐", str.tostring(p, format.mintick), dist >= 0 ? "+" : "", str.tostring(dist, "#.#")), style=label.style_label_left, color=color.new(c, 70), textcolor=c, size=size.small))

    // ---- B 真空區 LVN：低量連續桶併成帶，只標現價附近 ----
    if showVac
        [vhh, vll, vvol] = f_binvol(vacLen, vacBins)
        if vhh > vll and array.size(vvol) > 0
            vstep = (vhh - vll) / vacBins
            vavg  = array.avg(vvol)
            zlo = -1
            for j = 0 to vacBins - 1
                isLow = array.get(vvol, j) < vavg * vacThr
                if isLow and zlo == -1
                    zlo := j
                if (not isLow or j == vacBins - 1) and zlo != -1
                    zhi  = isLow ? j : j - 1
                    pTop = vll + (zhi + 1) * vstep
                    pBot = vll + zlo * vstep
                    pMid = (pTop + pBot) / 2
                    if pxNow > 0 and math.abs(pMid - pxNow) / pxNow * 100 <= vacNear
                        array.push(vacBoxes, box.new(xLn, pTop, xRn, pBot, border_color=color.new(color.purple, 60), bgcolor=color.new(color.purple, 82)))
                        array.push(srLabs, label.new(xRn, pMid, "真空區 多空分界", style=label.style_label_left, color=color.new(color.purple, 50), textcolor=color.white, size=size.tiny))
                    zlo := -1

// ===== 均線 MA5 / MA20 =====
plot(showMA5  ? ta.sma(close, 5)  : na, "MA5",  color=color.orange, linewidth=1)
plot(showMA20 ? ta.sma(close, 20) : na, "MA20", color=color.blue,   linewidth=2)

// swing 標記 (只 Pivot 模式顯示)
plotshape(isPivot and not na(ph), style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.tiny, offset=-pvRight)
plotshape(isPivot and not na(pl), style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.tiny, offset=-pvRight)
