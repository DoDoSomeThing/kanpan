//@version=5
indicator("Justin Fib 手動 + 判讀", overlay=true, max_lines_count=100, max_labels_count=100, max_boxes_count=100)

// ===== 手動鎖定波段高低 =====
manHi   = input.price(0.0, "手動高點價", group="手動錨點", tooltip="你自己挑的波段高點(0 = 未填)")
manLo   = input.price(0.0, "手動低點價", group="手動錨點", tooltip="你自己挑的波段低點(0 = 未填)")
manBack = input.int(60, "Fib 線往左畫幾根", minval=5, group="手動錨點")
rightExt= input.int(20, "向右延伸根數", group="手動錨點")

showFib   = input.bool(true, "Fib 線",   group="顯示")
showZones = input.bool(true, "Fib 色塊", group="顯示")
showMA5   = input.bool(true, "MA5",  group="顯示")
showMA20  = input.bool(true, "MA20", group="顯示")

// 關鍵水平線(自填)
h1 = input.price(0.0, "水平線1", group="關鍵價位")
h2 = input.price(0.0, "水平線2", group="關鍵價位")
h3 = input.price(0.0, "水平線3", group="關鍵價位")
h4 = input.price(0.0, "水平線4", group="關鍵價位")

// ===== 判讀 / 訊號 =====
grpAna     = "判讀 / 訊號"
showPanel  = input.bool(true, "位置判讀面板",   group=grpAna)
showSignals= input.bool(true, "進出場箭頭",     group=grpAna)
showVerdict= input.bool(true, "紅綠燈 verdict", group=grpAna)

// ===== 錨點 + Fib 價位(每根算,訊號要用)=====
hiP = manHi > 0 ? manHi : na
loP = manLo > 0 ? manLo : na
ok  = not na(hiP) and not na(loP) and hiP > loP
rng = hiP - loP

f0    = hiP
f236  = hiP - rng * 0.236
f382  = hiP - rng * 0.382
f5    = hiP - rng * 0.5
f618  = hiP - rng * 0.618
f786  = hiP - rng * 0.786
f1    = loP

ma5  = ta.sma(close, 5)
ma20 = ta.sma(close, 20)

// ===== verdict(每根算)=====
bull = ok and close > f5   and ma5 > ma20 and close > ma20
bear = ok and close < f618 and ma5 < ma20 and close < ma20
vcol = bull ? color.green : bear ? color.red : color.orange
vtxt = bull ? "偏多" : bear ? "偏空" : "中性"

// ===== 進出場箭頭(每根畫)=====
inGold = showSignals and ok and low <= f5 and low >= f618 and close > open
brk    = showSignals and ok and ta.crossover(close, f0)
plotshape(inGold, "回測黃金區", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, text="黃金區", textcolor=color.green)
plotshape(brk,    "突破高點",   style=shape.labelup,    location=location.belowbar, color=color.lime,  size=size.small, text="突破",   textcolor=color.white)

// ===== Fib 線 + 色塊 + 水平線(最後一根重畫)=====
levels = array.from(0.0, 0.236, 0.382, 0.5, 0.618, 0.786, 1.0, 1.618)
cols   = array.from(color.gray, color.red, color.orange, color.green, color.teal, color.aqua, color.gray, color.purple)
var line[]  fLines = array.new_line()
var label[] fLabs  = array.new_label()
var box[]   fBoxes = array.new_box()

if barstate.islast and ok
    if array.size(fLines) > 0
        for i = 0 to array.size(fLines) - 1
            line.delete(array.get(fLines, i))
    if array.size(fLabs) > 0
        for i = 0 to array.size(fLabs) - 1
            label.delete(array.get(fLabs, i))
    if array.size(fBoxes) > 0
        for i = 0 to array.size(fBoxes) - 1
            box.delete(array.get(fBoxes, i))
    array.clear(fLines)
    array.clear(fLabs)
    array.clear(fBoxes)

    xL = math.max(0, bar_index - manBack)
    xR = bar_index + rightExt
    px = close

    if showFib
        for i = 0 to array.size(levels) - 1
            r = array.get(levels, i)
            p = hiP - rng * r
            c = array.get(cols, i)
            sr = p > px ? "壓力" : "支撐"
            array.push(fLines, line.new(xL, p, xR, p, color=c, width=1))
            array.push(fLabs,  label.new(xR, p, str.format("{0} Fib {1} ({2})", sr, r, str.tostring(p, format.mintick)), style=label.style_label_left, color=color.new(c, 80), textcolor=c, size=size.small))

    if showZones
        for i = 0 to array.size(levels) - 2
            p1 = hiP - rng * array.get(levels, i)
            p2 = hiP - rng * array.get(levels, i + 1)
            array.push(fBoxes, box.new(xL, math.max(p1, p2), xR, math.min(p1, p2), border_color=color.new(color.gray, 100), bgcolor=color.new(array.get(cols, i + 1), 90)))

    // 關鍵水平線;壓力紅/支撐綠
    if h1 > 0
        c1 = h1 > px ? color.red : color.green
        array.push(fLines, line.new(xL, h1, xR, h1, color=c1, width=2))
        array.push(fLabs,  label.new(xR, h1, str.format("{0} {1}", h1 > px ? "壓力" : "支撐", str.tostring(h1)), style=label.style_label_left, color=color.new(c1, 50), textcolor=color.white, size=size.small))
    if h2 > 0
        c2 = h2 > px ? color.red : color.green
        array.push(fLines, line.new(xL, h2, xR, h2, color=c2, width=2))
        array.push(fLabs,  label.new(xR, h2, str.format("{0} {1}", h2 > px ? "壓力" : "支撐", str.tostring(h2)), style=label.style_label_left, color=color.new(c2, 50), textcolor=color.white, size=size.small))
    if h3 > 0
        c3 = h3 > px ? color.red : color.green
        array.push(fLines, line.new(xL, h3, xR, h3, color=c3, width=2))
        array.push(fLabs,  label.new(xR, h3, str.format("{0} {1}", h3 > px ? "壓力" : "支撐", str.tostring(h3)), style=label.style_label_left, color=color.new(c3, 50), textcolor=color.white, size=size.small))
    if h4 > 0
        c4 = h4 > px ? color.red : color.green
        array.push(fLines, line.new(xL, h4, xR, h4, color=c4, width=2))
        array.push(fLabs,  label.new(xR, h4, str.format("{0} {1}", h4 > px ? "壓力" : "支撐", str.tostring(h4)), style=label.style_label_left, color=color.new(c4, 50), textcolor=color.white, size=size.small))

// ===== 位置判讀面板(右上表格)=====
var table panel = table.new(position.top_right, 2, 6, border_width=1, frame_color=color.gray, frame_width=1)

if barstate.islast
    if showPanel and ok
        px = close
        // 最近壓力(現價上最小)/支撐(現價下最大)
        float up = na
        float dn = na
        for i = 0 to array.size(levels) - 1
            p = hiP - rng * array.get(levels, i)
            if p > px
                up := na(up) ? p : math.min(up, p)
            if p < px
                dn := na(dn) ? p : math.max(dn, p)
        // 判讀文字(現價落在哪個 Fib 區)
        zone = px > f0 ? "突破 0 高點,續強" : px > f236 ? "高檔強勢區(0~0.236)" : px > f382 ? "淺回撤(0.236~0.382)" : px > f5 ? "回撤健康(0.382~0.5)" : px > f618 ? "黃金回測區(0.5~0.618)" : px > f786 ? "回撤偏深(0.618~0.786)" : px > f1 ? "瀕臨破底(0.786~1)" : "跌破低點,轉弱"
        upPct = na(up) ? na : (up - px) / px * 100
        dnPct = na(dn) ? na : (dn - px) / px * 100

        table.clear(panel, 0, 0, 1, 5)
        table.cell(panel, 0, 0, "判讀", text_color=color.white, bgcolor=color.new(color.black, 20), text_size=size.small)
        table.cell(panel, 1, 0, showVerdict ? vtxt : "—", text_color=color.white, bgcolor=showVerdict ? vcol : color.new(color.gray, 30), text_size=size.small)
        table.cell(panel, 0, 1, "現價", text_color=color.silver, text_size=size.small)
        table.cell(panel, 1, 1, str.tostring(px, format.mintick), text_color=color.white, text_size=size.small)
        table.cell(panel, 0, 2, "位置", text_color=color.silver, text_size=size.small)
        table.cell(panel, 1, 2, zone, text_color=color.white, text_size=size.small)
        table.cell(panel, 0, 3, "壓力", text_color=color.silver, text_size=size.small)
        table.cell(panel, 1, 3, na(up) ? "—(已破頂)" : str.format("{0} (+{1}%)", str.tostring(up, format.mintick), str.tostring(upPct, "#.#")), text_color=color.red, text_size=size.small)
        table.cell(panel, 0, 4, "支撐", text_color=color.silver, text_size=size.small)
        table.cell(panel, 1, 4, na(dn) ? "—(已破底)" : str.format("{0} ({1}%)", str.tostring(dn, format.mintick), str.tostring(dnPct, "#.#")), text_color=color.green, text_size=size.small)
        table.cell(panel, 0, 5, "區間", text_color=color.silver, text_size=size.small)
        table.cell(panel, 1, 5, str.format("{0} ~ {1}", str.tostring(f1, format.mintick), str.tostring(f0, format.mintick)), text_color=color.white, text_size=size.small)
    else
        table.clear(panel, 0, 0, 1, 5)
        table.cell(panel, 0, 0, "請填手動高/低點", text_color=color.yellow, bgcolor=color.new(color.black, 20), text_size=size.small)

// ===== 均線 =====
plot(showMA5  ? ma5  : na, "MA5",  color=color.orange, linewidth=1)
plot(showMA20 ? ma20 : na, "MA20", color=color.blue,   linewidth=2)
